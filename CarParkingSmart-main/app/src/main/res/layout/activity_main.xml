<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_bg">

    <!-- Bản đồ -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Thanh tìm kiếm phía trên với gradient xanh lá -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:backgroundTint="@color/premium_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_premium_bg">

            <!-- Logo Trạm Sạc Xe Điện -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="8dp"
                android:src="@drawable/ic_ev_charging"
                android:contentDescription="EV Charging Logo"
                app:tint="@color/premium_purple_light" />

            <AutoCompleteTextView
                android:id="@+id/search_box"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Tìm kiếm trạm sạc, địa điểm..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:importantForAutofill="no"
                android:background="@null"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#CBD5E1"
                android:singleLine="true"
                android:paddingStart="4dp"
                android:paddingEnd="8dp"
                android:dropDownHeight="300dp"
                android:completionThreshold="2" />

            <!-- Icon microphone -->
            <ImageButton
                android:id="@+id/btn_voice"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voice search"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="#FFFFFF" />

            <!-- Avatar -->
            <ImageView
                android:id="@+id/user_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_electric_car"
                android:contentDescription="User Avatar"
                android:background="@drawable/circle_button" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_wards"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true"
            app:singleSelection="true"
            android:paddingEnd="12dp" />
    </HorizontalScrollView>

    <!-- Các nút chức năng bên phải (góc dưới phải) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="160dp"
        android:orientation="vertical">

        <!-- Nút Layers -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="@color/premium_card">

            <ImageButton
                android:id="@+id/btn_layers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Layers"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="@color/premium_blue" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút mở danh sách trạm sạc gần nhất -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="@color/premium_purple">

            <Button
                android:id="@+id/btn_show_parking_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="⚡"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút My Location -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="@color/premium_card">

            <ImageButton
                android:id="@+id/btn_my_location"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Vị trí của tôi"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="@color/premium_blue" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút mới: Lưu vị trí xe -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#66BB6A">

            <Button
                android:id="@+id/btn_save_my_spot"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="💾"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút mới: Tìm xe của tôi (ban đầu ẩn) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#8b5cf6">

            <Button
                android:id="@+id/btn_find_my_spot"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🔍"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:visibility="gone" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Nút Directions (FAB ở dưới trái) với gradient xanh -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_directions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:contentDescription="Chỉ đường"
        android:src="@android:drawable/ic_menu_directions"
        app:tint="#FFFFFF"
        app:backgroundTint="@color/premium_purple"
        app:elevation="8dp"
        app:borderWidth="0dp" />

    <!-- Bottom Sheet - Thông tin trạm sạc -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_sheet_bg"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- Handle Bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#8b5cf6"
            android:radius="2dp" />

        <!-- Header: Tên trạm sạc và nút đóng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_place_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tên trạm sạc"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:gravity="start" />

            <ImageButton
                android:id="@+id/btn_close_sheet"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Đóng"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white" />

        </LinearLayout>

        <!-- Nút đặt chỗ sạc (Hợp nhất Hierarchy) -->
        <Button
            android:id="@+id/btn_book_parking"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Đặt chỗ ngay"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/gradient_premium_bg"
            android:drawableStart="@android:drawable/ic_menu_my_calendar"
            android:drawablePadding="12dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginBottom="24dp"
            android:elevation="6dp"
            android:textAllCaps="false"
            android:visibility="gone" />

        <!-- Rating và category -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_place_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang tải..."
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_place_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạm sạc nhanh"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- Địa chỉ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="@color/premium_purple_light" />

            <TextView
                android:id="@+id/tv_place_address"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Địa chỉ"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Khoảng cách -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="@color/premium_purple_light" />

            <TextView
                android:id="@+id/tv_place_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.5 km từ vị trí của bạn"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Các nút hành động (Dàn đều không gian) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/btn_save_place"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="@color/premium_purple_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lưu"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_share_place"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="@color/premium_purple_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chia sẻ"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_nearby"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/premium_purple_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gần đây"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Nút chỉ đường (Secondary Outline) -->
        <Button
            android:id="@+id/btn_directions_bottom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Chỉ đường đến trạm sạc"
            android:textSize="16sp"
            android:textColor="@color/premium_purple"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary_outline"
            android:textAllCaps="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:gravity="center"
            android:elevation="0dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>